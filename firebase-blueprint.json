{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A single chat message",
      "type": "object",
      "properties": {
        "sender": { "type": "string", "enum": ["user", "iyra"] },
        "text": { "type": "string" },
        "ownerId": { "type": "string" },
        "sessionId": { "type": "string" },
        "deleted": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["sender", "text", "timestamp", "ownerId"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Public user profile information",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "ownerId": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data"
    },
    "/users/{userId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat message history for a specific user"
    }
  }
}
