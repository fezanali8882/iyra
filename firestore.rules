rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Support for test connection
    match /test/connection {
      allow read: if true;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      // Relaxing for development/Google auth where email_verified might be null in some contexts
      return isSignedIn(); 
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    // --- User Profiles ---
    match /users/{userAuthId} {
      // Users can only read/write their own profiles
      allow get: if isOwner(userAuthId);
      allow create: if isOwner(userAuthId) && isValidId(userAuthId);
      allow update: if isOwner(userAuthId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email', 'updatedAt', 'ownerId', 'createdAt'])
      );

      // --- Messages ---
      match /messages/{messageId} {
        // Users can only read/write their own messages
        allow list: if isOwner(userAuthId);
        allow get: if isOwner(userAuthId);
        allow create: if isOwner(userAuthId) && 
                      incoming().ownerId == request.auth.uid &&
                      incoming().sender in ['user', 'iyra'];
        allow update, delete: if isOwner(userAuthId);
      }
    }
  }
}
